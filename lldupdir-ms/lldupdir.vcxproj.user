<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <LocalDebuggerCommandArguments>-hide 2025-dlang-2 2022-dlang-3</LocalDebuggerCommandArguments>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
    <LocalDebuggerWorkingDirectory>e:\dlang-keep-backup</LocalDebuggerWorkingDirectory>
    <LocalDebuggerCommandArgumentsHistory> -no -delDupPat=Lawrence*  -all Lawrence\  \lawrence\2024-lawrence\2019-lawrence\| -all -justName -ignoreExtn test  org| -all -justName -ignoreExtn .| -all -justName -ignoreExtn test org|-hide 2025-dlang-2 2022-dlang-3|</LocalDebuggerCommandArgumentsHistory>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'">
    <LocalDebuggerCommandArguments> -inc=*.tax* -all -showabs   -delDupPat=2024-dlang  -no  taxes\  2024-dlang\</LocalDebuggerCommandArguments>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
    <LocalDebuggerWorkingDirectory>r:\</LocalDebuggerWorkingDirectory>
  </PropertyGroup>
</Project>